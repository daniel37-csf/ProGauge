{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and identification data",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "username": { "type": "string", "description": "User alias/alias" },
        "avatar": { "type": "string", "description": "User profile picture URL" },
        "bio": { "type": "string", "description": "User tactical biography" },
        "steamId": { "type": "string", "description": "Linked Steam 64-bit ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the user account was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when the user account was last updated" }
      },
      "required": ["email", "username", "createdAt", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Administrative privileges and role",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the admin user" },
        "role": { "type": "string", "enum": ["root", "moderator"], "description": "Admin level" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "email", "createdAt"]
    },
    "UsernameMap": {
      "title": "Username Mapping",
      "description": "Ensures username uniqueness and maps username to UID",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user's unique identification" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles"
    },
    "/admins/{userId}": {
      "schema": "Admin",
      "description": "Stores administrative privileges"
    },
    "/usernames/{username}": {
      "schema": "UsernameMap",
      "description": "Lookup table for username uniqueness and mapping"
    }
  }
}
